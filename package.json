{
  "private": true,
  "workspaces": ["packages/*", "examples/*"],
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "oxlint packages",
    "format:check": "bun run --filter '@lesto/*' format:check",
    "ws:test": "node scripts/require-node.mjs && bun run --filter '@lesto/*' test",
    "ws:test:cov": "node scripts/require-node.mjs && bun run scripts/coverage-gate.ts",
    "examples:test": "bun run --filter '@lesto/example-*' test",
    "bundle-size": "bun run --cwd packages/assets bundle-size",
    "ws:lint": "bun run --filter '@lesto/*' lint",
    "ws:format:check": "bun run --filter '@lesto/*' format:check",
    "ws:typecheck": "bun run --filter '@lesto/*' typecheck",
    "test:types": "tsc -p type-tests/tsconfig.json",
    "test:pack-boot": "node scripts/pack-and-boot.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.10.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "preact": "^10.29.2",
    "preact-render-to-string": "^6.7.0",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
