{
  "name": "@lesto/site",
  "version": "0.0.0",
  "private": true,
  "description": "The Lesto documentation site — a static, prerendered Lesto app whose pages are Markdown files rendered by @lesto/content-* at build time and served from Cloudflare's static-asset edge.",
  "type": "module",
  "scripts": {
    "dev": "lesto dev",
    "build": "lesto generate agents --check && lesto build",
    "deploy": "lesto generate agents --check && bun --bun lesto build && wrangler deploy",
    "agents": "lesto generate agents",
    "agents:check": "lesto generate agents --check",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lesto/assets": "workspace:*",
    "@lesto/cloudflare": "workspace:*",
    "@lesto/content-core": "workspace:*",
    "@lesto/content-markdown": "workspace:*",
    "@lesto/content-search": "workspace:*",
    "@lesto/kernel": "workspace:*",
    "@lesto/observability": "workspace:*",
    "@lesto/runtime": "workspace:*",
    "@lesto/seo": "workspace:*",
    "@lesto/sites": "workspace:*",
    "@lesto/styles": "workspace:*",
    "@lesto/ui": "workspace:*",
    "@lesto/web": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "preact": "^10.29.2",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@lesto/cli": "workspace:*"
  }
}
