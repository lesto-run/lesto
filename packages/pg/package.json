{
  "name": "@lesto/pg",
  "version": "0.1.5",
  "license": "MIT",
  "description": "Lesto's Postgres driver — adapts a node-postgres Pool to the async @lesto/db SqlDatabase seam (ADR 0006).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./translate": {
      "types": "./src/translate.ts",
      "import": "./src/translate.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/db": "workspace:*"
  },
  "peerDependencies": {
    "pg": "^8"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/pg"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
