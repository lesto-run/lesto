{
  "name": "@volo/observability",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's in-house distributed-tracing core — OpenTelemetry-shaped, with no OpenTelemetry dependency.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./rum": {
      "types": "./src/rum.ts",
      "import": "./src/rum.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
