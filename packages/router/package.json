{
  "name": "@keel/router",
  "version": "0.0.0",
  "description": "Keel's RESTful router — declare routes and named paths, resolve method+path to a controller#action.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },

  "dependencies": {
    "@keel/errors": "workspace:*"
  }
}
