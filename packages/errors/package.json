{
  "name": "@keel/errors",
  "version": "0.0.0",
  "description": "Keel's shared error foundation — the KeelError base every package error extends, plus a Result type.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
