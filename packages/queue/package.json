{
  "name": "@volo/queue",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's in-house durable job queue — at-least-once delivery on the SQL database, no Redis.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@volo/db": "workspace:*",
    "@volo/errors": "workspace:*"
  }
}
