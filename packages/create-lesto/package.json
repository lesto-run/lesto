{
  "name": "create-lesto",
  "version": "0.1.6",
  "license": "MIT",
  "description": "The Lesto project scaffolder — `bun create lesto <name>` / `npm create lesto <name>`.",
  "type": "module",
  "bin": {
    "create-lesto": "./bin/create-lesto.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/errors": "workspace:*",
    "jiti": "^2.7.0"
  },
  "devDependencies": {
    "@lesto/assets": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/create-lesto"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
