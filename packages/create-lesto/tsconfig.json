{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": ".",
    "types": ["node"],

    // The subset-guard test (`test/specifier-subset.test.ts`) imports `@lesto/assets`,
    // which ships its types AS SOURCE (`"types": "./src/index.ts"`) — so tsc typechecks
    // assets' `client-beacon.ts` (a browser runtime using `document`/`fetch`) under THIS
    // package's lib. The scaffolder's own src is DOM-free; DOM joins ES2023 only to admit
    // that imported client source, exactly as `@lesto/assets` itself carries DOM for `@lesto/ui`.
    "lib": ["ES2023", "DOM"]
  },

  "include": ["src", "test"]
}
