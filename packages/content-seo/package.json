{
  "name": "@keel/content-seo",
  "version": "0.1.0",
  "description": "PREVIEW (not part of the supported v1 content seam) — content-aware SEO analysis and entry-aware JSON-LD for Docks; experimental, coverage-gate-exempt.",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@keel/content-shared": "workspace:*"
  },
  "private": true
}
