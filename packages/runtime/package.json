{
  "name": "@keel/runtime",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "description": "Keel's transport tier — the node:http server that serves a Keel app, plus a queue-worker runner.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@keel/errors": "workspace:*",
    "@keel/kernel": "workspace:*",
    "@keel/queue": "workspace:*",
    "@keel/sites": "workspace:*",
    "@keel/web": "workspace:*"
  },
  "devDependencies": {
    "@keel/observability": "workspace:*"
  }
}
