{
  "name": "@lesto/runtime",
  "version": "0.1.3",
  "license": "MIT",
  "description": "Lesto's transport tier — the node:http server that serves a Lesto app, plus a queue-worker runner.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/csrf": "workspace:*",
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/kernel": "workspace:*",
    "@lesto/queue": "workspace:*",
    "@lesto/sites": "workspace:*",
    "@lesto/web": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@lesto/observability": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
