{
  "name": "@keel/db",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Keel's schema-and-query layer — a Drizzle-shaped, typed query DSL over the minimal SQL surface, with the schema as the single source of truth for both DDL and query types.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@keel/errors": "workspace:*"
  }
}
