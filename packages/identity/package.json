{
  "name": "@keel/identity",
  "version": "0.0.0",
  "description": "Keel's batteries-included auth: users on the SQL DB, register/verify/login/reset flows composed from @keel/auth + @keel/orm + @keel/migrate + @keel/mail + @keel/csrf.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },

  "dependencies": {
    "@keel/auth": "workspace:*",
    "@keel/errors": "workspace:*",
    "@keel/mail": "workspace:*",
    "@keel/migrate": "workspace:*",
    "@keel/orm": "workspace:*"
  }
}
