{
  "name": "@volo/identity",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's batteries-included auth: users on the SQL DB, register/verify/login/reset flows composed from @volo/auth + @volo/db + @volo/migrate + @volo/mail + @volo/csrf.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@volo/auth": "workspace:*",
    "@volo/db": "workspace:*",
    "@volo/errors": "workspace:*",
    "@volo/mail": "workspace:*",
    "@volo/migrate": "workspace:*",
    "@volo/ratelimit": "workspace:*"
  }
}
