{
  "name": "@lesto/identity",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Lesto's batteries-included auth: users on the SQL DB, register/verify/login/reset flows composed from @lesto/auth + @lesto/db + @lesto/migrate + @lesto/mail + @lesto/csrf.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/auth": "workspace:*",
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/mail": "workspace:*",
    "@lesto/migrate": "workspace:*",
    "@lesto/ratelimit": "workspace:*"
  }
}
