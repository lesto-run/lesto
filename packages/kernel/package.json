{
  "name": "@lesto/kernel",
  "version": "0.1.3",
  "license": "MIT",
  "description": "Lesto's application kernel — assembles the database, migrations, router, and controllers into one bootable app.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/auth": "workspace:*",
    "@lesto/cors": "workspace:*",
    "@lesto/csrf": "workspace:*",
    "@lesto/db": "workspace:*",
    "@lesto/migrate": "workspace:*",
    "@lesto/ratelimit": "workspace:*",
    "@lesto/router": "workspace:*",
    "@lesto/web": "workspace:*"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/kernel"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
