{
  "name": "create-volo",
  "version": "0.0.0",
  "license": "MIT",
  "description": "The Volo project scaffolder — `bun create volo <name>` / `npm create volo <name>`.",
  "type": "module",
  "private": true,
  "bin": "./src/bin.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@volo/errors": "workspace:*"
  }
}
