{
  "name": "@lesto/cli",
  "version": "0.1.1",
  "license": "MIT",
  "description": "Lesto's `lesto` command-line tool — load a project's lesto.app.ts and run, serve, migrate, or inspect routes.",
  "bin": {
    "lesto": "./bin/lesto.mjs"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/assets": "workspace:*",
    "@lesto/deploy": "workspace:*",
    "@lesto/env": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/kernel": "workspace:*",
    "@lesto/mcp": "workspace:*",
    "@lesto/migrate": "workspace:*",
    "@lesto/observability": "workspace:*",
    "@lesto/openapi": "workspace:*",
    "@lesto/router": "workspace:*",
    "@lesto/runtime": "workspace:*",
    "@lesto/sites": "workspace:*",
    "@lesto/web": "workspace:*",
    "jiti": "^2.7.0"
  },
  "peerDependencies": {
    "@lesto/content-core": "workspace:*",
    "@lesto/content-store": "workspace:*",
    "@lesto/styles": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@lesto/content-core": {
      "optional": true
    },
    "@lesto/content-store": {
      "optional": true
    },
    "@lesto/styles": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/cli"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
