{
  "name": "@lesto/cli",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "description": "Lesto's `lesto` command-line tool — load a project's lesto.app.ts and run, serve, migrate, or inspect routes.",
  "bin": {
    "lesto": "./src/bin.ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/assets": "workspace:*",
    "@lesto/content-core": "workspace:*",
    "@lesto/content-store": "workspace:*",
    "@lesto/deploy": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/kernel": "workspace:*",
    "@lesto/mcp": "workspace:*",
    "@lesto/migrate": "workspace:*",
    "@lesto/observability": "workspace:*",
    "@lesto/openapi": "workspace:*",
    "@lesto/router": "workspace:*",
    "@lesto/runtime": "workspace:*",
    "@lesto/sites": "workspace:*",
    "@lesto/web": "workspace:*"
  }
}
