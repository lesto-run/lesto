{
  "name": "@volo/cli",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "description": "Volo's `volo` command-line tool — load a project's volo.app.ts and run, serve, migrate, or inspect routes.",
  "bin": {
    "volo": "./src/bin.ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@volo/assets": "workspace:*",
    "@volo/content-core": "workspace:*",
    "@volo/content-store": "workspace:*",
    "@volo/deploy": "workspace:*",
    "@volo/errors": "workspace:*",
    "@volo/kernel": "workspace:*",
    "@volo/mcp": "workspace:*",
    "@volo/migrate": "workspace:*",
    "@volo/observability": "workspace:*",
    "@volo/openapi": "workspace:*",
    "@volo/router": "workspace:*",
    "@volo/runtime": "workspace:*",
    "@volo/sites": "workspace:*",
    "@volo/web": "workspace:*"
  }
}
