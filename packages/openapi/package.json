{
  "name": "@volo/openapi",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's OpenAPI generator — turn a Volo app's route list into an OpenAPI 3.1 document.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {}
}
