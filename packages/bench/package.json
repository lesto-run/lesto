{
  "name": "@lesto/bench",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Lesto's benchmark harness — req/s + p99, queue throughput, and SSR render-path numbers, tracked across runs. Private; never published.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "lesto-bench": "./src/bin.ts"
  },
  "scripts": {
    "bench": "bun run src/bin.ts",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/errors": "workspace:*",
    "@lesto/queue": "workspace:*",
    "@lesto/runtime": "workspace:*",
    "@lesto/ui": "workspace:*"
  }
}
