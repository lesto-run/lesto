{
  "name": "@lesto/content-store",
  "version": "0.1.3",
  "license": "MIT",
  "description": "SUPPORTED (v1 content seam) — Lesto content on the SQL substrate — persists @lesto/content-core entries to the database and hydrates the runtime from it.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/content-core": "workspace:*",
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/migrate": "workspace:*"
  },
  "devDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/content-store"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
