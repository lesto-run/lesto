{
  "name": "@lesto/content-store",
  "version": "0.0.0",
  "license": "MIT",
  "description": "SUPPORTED (v1 content seam) — Lesto content on the SQL substrate — persists @lesto/content-core entries to the database and hydrates the runtime from it.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/content-core": "workspace:*",
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/migrate": "workspace:*"
  },
  "devDependencies": {
    "better-sqlite3": "^11.10.0"
  }
}
