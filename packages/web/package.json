{
  "name": "@lesto/web",
  "version": "0.1.7",
  "license": "MIT",
  "description": "Lesto's MVC request-handling core — a Rails-style controller layer that weds @lesto/router and @lesto/ui.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/errors": "workspace:*",
    "@lesto/observability": "workspace:*",
    "@lesto/router": "workspace:*",
    "@lesto/ui": "workspace:*",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/web"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
