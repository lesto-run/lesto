{
  "name": "@lesto/ui-generate",
  "version": "0.0.0",
  "license": "MIT",
  "description": "AI generation of validated @lesto/ui trees — build the registry schema as a forced tool, ask a model, validate the result.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@lesto/errors": "workspace:*",
    "@lesto/ui": "workspace:*"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
