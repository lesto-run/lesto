{
  "name": "@lesto/mcp",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Lesto's MCP control plane — exposes Lesto operations to AI agents as MCP tools over @modelcontextprotocol/sdk.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/content-core": "workspace:*",
    "@lesto/content-store": "workspace:*",
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/kernel": "workspace:*",
    "@lesto/migrate": "workspace:*",
    "@lesto/web": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
