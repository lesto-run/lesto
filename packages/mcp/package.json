{
  "name": "@lesto/mcp",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Lesto's MCP control plane — exposes Lesto operations to AI agents as MCP tools over @modelcontextprotocol/sdk.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/authz": "workspace:*",
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/kernel": "workspace:*",
    "@lesto/migrate": "workspace:*",
    "@lesto/openapi": "workspace:*",
    "@lesto/web": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@lesto/content-core": "workspace:>=0.1.0",
    "@lesto/content-store": "workspace:>=0.1.0"
  },
  "peerDependenciesMeta": {
    "@lesto/content-core": {
      "optional": true
    },
    "@lesto/content-store": {
      "optional": true
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
