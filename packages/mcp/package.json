{
  "name": "@volo/mcp",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's MCP control plane — exposes Volo operations to AI agents as MCP tools over @modelcontextprotocol/sdk.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@volo/content-core": "workspace:*",
    "@volo/content-store": "workspace:*",
    "@volo/db": "workspace:*",
    "@volo/errors": "workspace:*",
    "@volo/kernel": "workspace:*",
    "@volo/migrate": "workspace:*",
    "@volo/web": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
