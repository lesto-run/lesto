{
  "name": "@lesto/content-embeddings",
  "version": "0.2.0",
  "description": "PREVIEW (not part of the supported v1 content seam) — build-time embedding generation for semantic search. A fresh build environment downloads the all-MiniLM-L6-v2 model (~25MB via @huggingface/transformers) on first run; cache the model dir in CI. Experimental, coverage-gate-exempt.",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "keywords": [
    "docks",
    "embeddings",
    "semantic-search",
    "ai",
    "build-time"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.3.3",
    "@lesto/content-shared": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.17.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/content-embeddings"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
