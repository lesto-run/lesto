{
  "name": "@keel/hooks",
  "version": "0.0.0",
  "description": "Keel's WordPress-style extensibility core — actions (side effects) and filters (value transforms), instance-based and pure.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
