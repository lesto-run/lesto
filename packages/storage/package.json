{
  "name": "@volo/storage",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's object storage — a pluggable backend (S3/R2 for production; in-memory and local filesystem for dev).",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@volo/errors": "workspace:*"
  }
}
