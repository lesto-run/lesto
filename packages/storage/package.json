{
  "name": "@keel/storage",
  "version": "0.0.0",
  "description": "Keel's object storage — a pluggable backend (in-memory, local filesystem; S3 to come).",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },

  "dependencies": {
    "@keel/errors": "workspace:*"
  }
}
