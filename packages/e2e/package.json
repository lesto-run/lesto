{
  "name": "lesto-e2e",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "description": "Lesto's browser E2E suite — Playwright against a minimal in-repo island fixture, proving hydration in a real browser. Named outside @lesto/* so the workspace test filter skips it; run by its own CI job.",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test island-hydration.spec.ts",
    "test:scaffold": "playwright test scaffold-loop.spec.ts",
    "test:island-hmr": "playwright test island-fast-refresh.spec.ts",
    "test:island-concurrent": "playwright test island-dev-concurrent.spec.ts",
    "test:page-swap": "playwright test page-swap.spec.ts",
    "test:bundler-parity": "playwright test island-bundler-parity.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lesto/runtime": "workspace:*",
    "@lesto/ui": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.515.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.4"
  }
}
