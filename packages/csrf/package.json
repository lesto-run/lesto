{
  "name": "@lesto/csrf",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Lesto's stateless double-submit CSRF tokens — HMAC-signed nonces, no server-side state.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/errors": "workspace:*",
    "@lesto/web": "workspace:*"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
