{
  "name": "@keel/mailing-lists",
  "version": "0.0.0",
  "description": "Ghost-style subscriber lists — double opt-in and broadcasts, composed on @keel/orm, @keel/mail, and @keel/queue.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "dependencies": {
    "@keel/errors": "workspace:*",
    "@keel/mail": "workspace:*",
    "@keel/orm": "workspace:*",
    "@keel/queue": "workspace:*"
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
