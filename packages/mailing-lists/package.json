{
  "name": "@lesto/mailing-lists",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Ghost-style subscriber lists — double opt-in and broadcasts, composed on @lesto/db, @lesto/mail, and @lesto/queue.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/mail": "workspace:*",
    "@lesto/migrate": "workspace:*",
    "@lesto/queue": "workspace:*"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/mailing-lists"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
