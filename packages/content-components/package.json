{
  "name": "@volo/content-components",
  "version": "0.1.0",
  "description": "HTML rendering components for Docks content collections. SUPPORTED surface is HtmlContent only; components beyond HtmlContent ship PREVIEW (experimental, coverage-gate-exempt).",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./react": {
      "types": "./react/index.ts",
      "import": "./react/index.ts"
    },
    "./vue": {
      "types": "./vue/index.ts",
      "import": "./vue/index.ts"
    },
    "./svelte": {
      "types": "./svelte/index.ts",
      "import": "./svelte/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint react vue svelte test",
    "format": "oxfmt react vue svelte test",
    "format:check": "oxfmt --check react vue svelte test"
  },
  "keywords": [
    "docks",
    "components",
    "react",
    "vue",
    "svelte",
    "html",
    "markdown"
  ],
  "author": "Docks Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usedocks/docks.git",
    "directory": "packages/components"
  },
  "bugs": {
    "url": "https://github.com/usedocks/docks/issues"
  },
  "homepage": "https://github.com/usedocks/docks/tree/main/packages/components#readme",
  "dependencies": {
    "@volo/content-shared": "workspace:*"
  },
  "peerDependencies": {
    "@volo/content-mdx": "workspace:*",
    "react": ">=18",
    "react-dom": ">=18",
    "vue": ">=3",
    "svelte": ">=4"
  },
  "peerDependenciesMeta": {
    "@volo/content-mdx": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsdown": "^0.17.3",
    "vue": "^3.0.0",
    "svelte": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
