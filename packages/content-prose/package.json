{
  "name": "@keel/content-prose",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@keel/content-shared": "workspace:*",
    "cuss": "^2.0.0",
    "fillers": "^2.0.0",
    "hedges": "^2.0.0",
    "no-cliches": "^0.3.6",
    "typo-js": "^1.2.5",
    "weasels": "^2.0.0"
  },
  "devDependencies": {
    "@types/typo-js": "^1.2.2"
  },
  "private": true
}
