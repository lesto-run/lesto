{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": ".",
    "types": ["node"],

    // Typechecking reaches into @lesto/web's source (types point at .tsx), so the
    // JSX flag must be set even though this package authors no JSX itself.
    "jsx": "react-jsx"
  },

  "include": ["src", "test"]
}
