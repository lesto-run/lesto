{
  "name": "@volo/authz",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's first-class authorization — a declarative role/permission policy and the guard middleware that enforces it.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@volo/errors": "workspace:*",
    "@volo/web": "workspace:*"
  }
}
