{
  "name": "@volo/ui",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's AI-native UI rendering engine core — validate a JSON UI tree and render it to React against a vetted component registry.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    }
  },
  "dependencies": {
    "@volo/errors": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependencies": {
    "preact-render-to-string": "^6"
  },
  "peerDependenciesMeta": {
    "preact-render-to-string": {
      "optional": true
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
