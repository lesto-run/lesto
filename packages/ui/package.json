{
  "name": "@keel/ui",
  "version": "0.0.0",
  "description": "Keel's AI-native UI rendering engine core — validate a JSON UI tree and render it to React against a vetted component registry.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/hydrate.tsx",
      "import": "./src/hydrate.tsx"
    }
  },

  "dependencies": {
    "@keel/errors": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
