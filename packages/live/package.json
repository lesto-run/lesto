{
  "name": "@lesto/live",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Lesto local-first sync (ADR 0042 Tier 4) — the browser client: an in-memory keyed store (default) or an opt-in durable OPFS-SQLite store that persists rows + the LSN cursor atomically and survives reload, the GET /__lesto/live-data SSE consumer, and a framework-agnostic LiveQuery handle (subscribe/getSnapshot) that keeps an auth-scoped shape in sync.",
  "type": "module",
  "private": true,
  "dependencies": {
    "@lesto/db": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/live-protocol": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./opfs": {
      "types": "./src/opfs-sqlite.ts",
      "import": "./src/opfs-sqlite.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts"
    }
  },
  "peerDependencies": {
    "@sqlite.org/sqlite-wasm": "^3.46.1-build5",
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "@sqlite.org/sqlite-wasm": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sqlite.org/sqlite-wasm": "3.46.1-build5",
    "react": "^19",
    "react-dom": "^19"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
