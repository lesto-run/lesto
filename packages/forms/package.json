{
  "name": "@keel/forms",
  "version": "0.0.0",
  "description": "Keel's schema-driven forms — a form spec, a render to a @keel/ui tree, and submission validation. Ships its own form components.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "dependencies": {
    "@keel/errors": "workspace:*",
    "@keel/ui": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
