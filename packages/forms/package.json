{
  "name": "@volo/forms",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Volo's schema-driven forms — a form spec, a render to a @volo/ui tree, and submission validation. Ships its own form components.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@volo/errors": "workspace:*",
    "@volo/ui": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
