{
  "name": "@lesto/forms",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Lesto's schema-driven forms — a form spec, a render to a @lesto/ui tree, and submission validation. Ships its own form components.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/errors": "workspace:*",
    "@lesto/ui": "workspace:*",
    "react": "^19"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/forms"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  },
  "devDependencies": {
    "react-dom": "^19"
  }
}
