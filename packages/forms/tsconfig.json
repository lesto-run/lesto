{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": ".",
    "types": ["node"],

    // Importing `@lesto/ui` pulls its `src` (types → source under Bundler resolution), including the
    // browser `data-client.ts` (`window`/`document`), so the DOM lib joins ES2023 as it does in
    // `@lesto/ui` itself. (Previously satisfied only incidentally, via DOM globals leaked from
    // `preact-render-to-string`'s types through `@lesto/ui/server` — no longer re-exported.)
    "lib": ["ES2023", "DOM"],

    "jsx": "react-jsx"
  },

  "include": ["src", "test"]
}
