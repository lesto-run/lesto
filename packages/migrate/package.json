{
  "name": "@keel/migrate",
  "version": "0.0.0",
  "description": "Keel's migrator — a Tracks-style migration system (ordering, bookkeeping, indexes) over @keel/db schema-as-value DDL on an injected SQL database.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },

  "dependencies": {
    "@keel/errors": "workspace:*"
  },

  "devDependencies": {
    "@keel/db": "workspace:*",
    "better-sqlite3": "^11.10.0"
  }
}
