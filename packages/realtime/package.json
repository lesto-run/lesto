{
  "name": "@lesto/realtime",
  "version": "0.1.5",
  "license": "MIT",
  "description": "Lesto's realtime transport (ADR 0040) — the cross-process topic bus + SSE fan-out behind the in-process @lesto/pubsub hub. This package holds the pure cores: the resume-cursor replay ring and the transport seam.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@lesto/pubsub": "workspace:*",
    "@lesto/web": "workspace:*"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/realtime"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
