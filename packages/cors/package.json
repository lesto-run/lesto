{
  "name": "@keel/cors",
  "version": "0.0.0",
  "description": "Keel's CORS header computation — pure, dependency-free Access-Control-* resolution.",
  "type": "module",
  "private": true,

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "dependencies": {
    "@keel/errors": "workspace:*",
    "@keel/web": "workspace:*"
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
