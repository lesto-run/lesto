{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": ".",
    "types": ["node", "bun"]
  },

  // `scripts/` holds the standalone Bun bundle-size assertion — Bun-run, not
  // vitest, but still typechecked.
  "include": ["src", "test", "scripts"],

  // The island fixture under `scripts/fixture-islands` is a JSX bundler input
  // (compiled by `Bun.build`, which owns JSX), not a tsc-compiled module — this
  // package is otherwise JSX-free and sets no `jsx` option. It is typechecked by
  // its use in the client graph the script builds, not here.
  "exclude": ["scripts/fixture-islands"]
}
