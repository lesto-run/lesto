{
  "name": "@lesto/assets",
  "version": "0.1.6",
  "license": "MIT",
  "description": "Lesto's client-asset pipeline — synthesize the island hydration entry from an app/islands convention and bundle it (Vite/Rolldown for `lesto build`, sharing one bundler with the dev island server; Bun.build as the dev fallback; splitting + the opt-in preact dialect), so an app ships an optimized /client.js with no bespoke build script.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "bundle-size": "bun run scripts/bundle-size.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test scripts",
    "format": "oxfmt src test scripts",
    "format:check": "oxfmt --check src test scripts"
  },
  "dependencies": {
    "@lesto/errors": "workspace:*",
    "@lesto/observability": "workspace:*",
    "jiti": "^2.7.0",
    "preact": "^10.29.2",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@lesto/ui": "workspace:*",
    "@types/bun": "^1.3.14",
    "react": "^19",
    "react-dom": "^19"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/assets"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
