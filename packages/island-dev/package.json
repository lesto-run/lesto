{
  "name": "@lesto/island-dev",
  "version": "0.1.2",
  "license": "MIT",
  "description": "Lesto's dev-only island bundler (DX-parity R2, ADR 0011) — a loopback Vite dev server (CLI-proxied) with React/Preact Fast Refresh, wrapped behind a pure seam so `lesto dev` preserves island state on edit. The real Vite + plugin wiring lives in a separate coverage-excluded edge; the orchestration is covered with fakes.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@lesto/assets": "workspace:*",
    "@lesto/errors": "workspace:*",
    "@lesto/web": "workspace:*",
    "@prefresh/vite": "3.0.1",
    "@vitejs/plugin-react": "4.7.0",
    "vite": "^7.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesto-run/lesto.git",
    "directory": "packages/island-dev"
  },
  "homepage": "https://lesto.run",
  "bugs": {
    "url": "https://github.com/lesto-run/lesto/issues"
  }
}
