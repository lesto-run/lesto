{
  "name": "@keel/admin",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Keel's admin operations layer — CRUD over a @keel/db Table with Zod-validated input, the backbone for a generic admin UI.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@keel/db": "workspace:*",
    "@keel/errors": "workspace:*",
    "zod": "^4.0.0"
  }
}
