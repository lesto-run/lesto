{
  "name": "@keel/mail",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Keel mailers — react-email templates, queued delivery on @keel/queue, pluggable transport.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@keel/errors": "workspace:*",
    "@keel/queue": "workspace:*"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  }
}
