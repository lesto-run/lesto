{
  "name": "create-keel",
  "version": "0.0.0",
  "description": "The Keel project scaffolder — `bun create keel <name>` / `npm create keel <name>`.",
  "type": "module",
  "private": true,

  "bin": "./src/bin.ts",

  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },

  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },

  "dependencies": {
    "@keel/errors": "workspace:*"
  }
}
