{
  "name": "@keel/deploy",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Keel deploy adapters — turn a built site set into a concrete deploy plan and ship its static targets through an injected uploader.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test"
  },
  "dependencies": {
    "@keel/errors": "workspace:*",
    "@keel/sites": "workspace:*",
    "@keel/storage": "workspace:*"
  }
}
