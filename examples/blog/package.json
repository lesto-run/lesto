    "@keel/migrate": "workspace:*",
    "@keel/runtime": "workspace:*",
    "@keel/ui": "workspace:*",
    "@keel/web": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "react": "^19",
    "react-dom": "^19"
  }
}
