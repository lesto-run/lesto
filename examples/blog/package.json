{
  "name": "@volo/example-blog",
  "version": "0.0.0",
  "private": true,
  "description": "A runnable end-to-end Volo app: typed schema + migration + a code-first volo() app with a streamed .page and a JSON route, booted by the kernel.",
  "type": "module",
  "scripts": {
    "start": "bun run run.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@volo/db": "workspace:*",
    "@volo/kernel": "workspace:*",
    "@volo/migrate": "workspace:*",
    "@volo/runtime": "workspace:*",
    "@volo/ui": "workspace:*",
    "@volo/web": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "react": "^19",
    "react-dom": "^19"
  }
}
