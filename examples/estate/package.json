    "@lesto/observability": "workspace:*",
    "@lesto/ratelimit": "workspace:*",
    "@lesto/runtime": "workspace:*",
    "@lesto/sites": "workspace:*",
    "@lesto/ui": "workspace:*",
    "@lesto/web": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "better-sqlite3": "^11.10.0",
    "postgres": "^3.4.9",
