{
  "name": "@volo/example-estate",
  "version": "0.0.0",
  "private": true,
  "description": "Auth-aware static: a static marketing site at / and a dynamic authed app at /mls, two zones on one origin sharing one session.",
  "type": "module",
  "scripts": {
    "start": "bun run serve.ts",
    "build": "bun run build.ts",
    "deploy": "bun run build.ts && wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@volo/admin": "workspace:*",
    "@volo/auth": "workspace:*",
    "@volo/authz": "workspace:*",
    "@volo/client": "workspace:*",
    "@volo/cloudflare": "workspace:*",
    "@volo/csrf": "workspace:*",
    "@volo/db": "workspace:*",
    "@volo/flags": "workspace:*",
    "@volo/identity": "workspace:*",
    "@volo/migrate": "workspace:*",
    "@volo/observability": "workspace:*",
    "@volo/ratelimit": "workspace:*",
    "@volo/runtime": "workspace:*",
    "@volo/sites": "workspace:*",
    "@volo/ui": "workspace:*",
    "@volo/web": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "better-sqlite3": "^11.10.0",
    "postgres": "^3.4.9",
    "preact": "^10.29.2",
    "preact-render-to-string": "^6",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.0.0"
  }
