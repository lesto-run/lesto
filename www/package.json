{
  "name": "@lesto/www",
  "version": "0.0.0",
  "private": true,
  "description": "The Lesto marketing site (lesto.run) — a static, prerendered Lesto app: a hand-built landing page plus the blog, changelog, and use-cases, served from Cloudflare's static-asset edge.",
  "type": "module",
  "scripts": {
    "dev": "lesto dev",
    "build": "bun --bun lesto build",
    "deploy": "bun --bun lesto build && wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lesto/assets": "workspace:*",
    "@lesto/cloudflare": "workspace:*",
    "@lesto/content-core": "workspace:*",
    "@lesto/content-markdown": "workspace:*",
    "@lesto/kernel": "workspace:*",
    "@lesto/runtime": "workspace:*",
    "@lesto/seo": "workspace:*",
    "@lesto/sites": "workspace:*",
    "@lesto/styles": "workspace:*",
    "@lesto/ui": "workspace:*",
    "@lesto/web": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "preact": "^10.29.2",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@lesto/cli": "workspace:*"
  }
}
